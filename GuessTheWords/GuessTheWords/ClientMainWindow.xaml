    DESCRIPTION   : Main window XAML for the Guess The Word Game UI.
	                Has panels for the Start page and the actual game.
-->
<Window x:Class="GuessTheWords.ClientMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GuessTheWords"
        mc:Ignorable="d"
        Title="Guess The Words Game!" Height="620" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <!--Start Page-->
        <!--BIBI!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!-->
        <StackPanel x:Name="StartPage" Visibility="Hidden" Background="#ffeedd">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0" Background="#FFDCB9" 
                   FontFamily="Kartika"
                   FontSize="50"
                   HorizontalAlignment="Center"
                   FontWeight="ExtraBold"
                   Padding="0,30,0,30"
                   Foreground="#210f04">
             Guess the Words 🔎
                </TextBlock>
            </Grid>
        </StackPanel>
        <!--Game Page-->
        <!--Julia!!!!!!!!!!!!!!!!!!!!!!!!!!!!-->
        <StackPanel x:Name="GamePage" Visibility="Hidden" Background="#ffeedd">
            <!--MAIN GRID-->
            <Grid>
                <Grid.RowDefinitions>
                    <!--0: Title and Help Button-->
                    <RowDefinition Height="Auto"/>
                    <!--1: String Space-->
                    <RowDefinition Height="Auto"/>
                    <!--2: Game Space-->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title and Help Button Grid-->
                <Grid Grid.Row="0" Background="#FFDCB9">
                    <Grid.ColumnDefinitions>
                        <!--0: Title and Help Button-->
                        <ColumnDefinition Width="0.8*"/>
                        <!--1: String Space-->
                        <ColumnDefinition Width="0.2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                            FontFamily="Kartika"
                            FontSize="50"
                            HorizontalAlignment="Center"
                            FontWeight="ExtraBold"
                            Padding="80,20"
                            Foreground="#210f04"
                            >
                        Guess the Words 🔎</TextBlock>

                    <Button Name="HelpButton"
                            Click="help_Click"
                            Grid.Column="1"
                            FontFamily="Kartika"
                            Content="?"
                            FontSize="50"
                            Width="100"
                            Padding="5"
                            Height="70"
                            Foreground="#210f04"
                            Background="#FFDCB9"
                            BorderBrush="#210f04"
                            BorderThickness="5"
                            HorizontalAlignment="Center"/>
                </Grid>

                <!--String Space-->
                <TextBlock Name="StringSpace"
                           Grid.Row="1"
                           TextAlignment="Center"
                           Padding="20, 40"
                           FontSize="40"
                           Foreground="#210f04"
                    >ABCDCHANGETHISLATERPLEASEAAAAA</TextBlock>

                <!--Game Space Grid-->
                <Grid Grid.Row="2" Background="#FFCB98">
                    <Grid.ColumnDefinitions>
                        <!--0: User Input Side-->
                        <ColumnDefinition Width="*"/>
                        <!--1: Words Found Tracking Side-->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!--LEFT SIDE: User Input Side-->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <!--0: Guess Text Box Label-->
                            <RowDefinition Height="0.1*"/>
                            <!--1: Guess Text Input Box-->
                            <RowDefinition Height="0.1*"/>
                            <!--2: Guess Submit Button Space-->
                            <RowDefinition Height="0.1*"/>
                            <!--3: Space for Feedback on Guess-->
                            <RowDefinition Height="0.3*"/>
                            <!--4: Timer Label-->
                            <RowDefinition Height="0.1*"/>
                            <!--5: Timer Display-->
                            <RowDefinition Height="0.2*"/>
                            <!--6: Time Unit Labels-->
                            <RowDefinition Height="0.1*"/>
                        </Grid.RowDefinitions>

                        <!--Guess Text Box Label-->
                        <TextBlock Name="GuessTextBoxLabel"
                                   Grid.Row="0"
                                   FontWeight="Bold"
                                   FontSize="20"
                                   Padding="10"
                                   HorizontalAlignment="Center"
                                   Foreground="#210f04"
                                   >ENTER GUESS:</TextBlock>

                        <!--Guess Text Input Box-->
                        <TextBox Name="GuessTextBox"
                                 Grid.Row="1"
                                 Padding="5"
                                 HorizontalAlignment="Center"
                                 Width="350"
                                 FontSize="15"
                                 ></TextBox>

                        <!--Guess Submit Button-->
                        <Button Name="SubmitGuessButton"
                                Click="submitGuess_Click"
                                Grid.Row="2"
                                Content="GUESS!"
                                Width="200"
                                Padding="2"
                                Margin="0,10"
                                Background="#FF9832"
                                Foreground="#210f04"
                                BorderBrush="#210f04"
                                FontWeight="Bold"
                                FontSize="15"
                                />

                        <!--Guess Feedback Space -->
                        <TextBlock Name="GuessFeedback"
                                   Grid.Row="3"
                                   Padding="5"
                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   ></TextBlock>

                        <!--Timer Label-->
                        <TextBlock Name="TimerLabel"
                                   Grid.Row="4"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   Padding="0,50,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="#210f04"
                       
                                   >
                            TIME LEFT
                        </TextBlock>

                        <!--Timer-->
                        <TextBlock Name="TimerDisplay"
                                   Grid.Row="5"
                                   FontSize="70"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="#43B3AE"
                                   HorizontalAlignment="Center"
                                   >00:00</TextBlock>

                        <!--Time Unit Labels-->
                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <!--0: Minutes-->
                                <ColumnDefinition Width="*"/>
                                <!--1: Seconds-->
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!--Minutes Label-->
                            <TextBlock Name="MinutesLabel"
                                       Grid.Column="0"
                                       HorizontalAlignment="Right"
                                       FontWeight="ExtraBold"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       Padding="0,0,40,10"
                                       Foreground="#266663"
                                >
                                MIN
                            </TextBlock>

                            <!--Seconds Label-->
                            <TextBlock Name="SecondsLabel"
                                       Grid.Column="1"
                                       HorizontalAlignment="Left"
                                       FontWeight="ExtraBold"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       Padding="40,0,0,10"
                                       Foreground="#266663"
                                >
                                SEC
                            </TextBlock>
                        </Grid>
                    </Grid>
                    
                    <!--RIGHT SIDE: Words Found Side-->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <!--0: Info-->
                            <RowDefinition Height="1*"/>
                            <!--1: List Box of Found Words-->
                            <RowDefinition Height="3*"/>
                        </Grid.RowDefinitions>
                        
                        <!--Info-->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <!--0: Label-->
                                <ColumnDefinition Width="2*"/>
                                <!--1: Word Score-->
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Name="WordsFoundLabel"
                                       Grid.Column="0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="30"
                                       FontWeight="Bold"
                                >
                                WORDS FOUND:
                            </TextBlock>
                            <TextBlock Name="WordsFoundCount"
                                       Grid.Column="1"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="#1C4D4A"
                                >
                                30/30
                            </TextBlock>
                        </Grid>
                        
                        <!--List Box of Found Words-->
                        <ListBox Name="FoundWordsList" 
                                 Grid.Row="1"
                                 Height="250"
                                 Width="350"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Background="#E3F5F4"
                                 Foreground="#4E794E"
                                 FontWeight="Bold"
                                 FontFamily="Arial Rounded MT Bold"
                                 FontSize="15"
                                 Padding="5"
                            />
                    </Grid>


                </Grid>

            </Grid>
        </StackPanel>
        
        <!--ALL THE RESULTS PANELS~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~-->
        <!--WIN SCREEN: Player found all the words before the time ran out-->
        <StackPanel x:Name="WinResult" Visibility="Visible" Background="#BFE1BF">
            <Grid>
                
            </Grid>
        </StackPanel>
        
        <!--OUT OF TIME SCREEN: Player ran out of time before finding all the words-->
        <StackPanel x:Name="TimeOutResult" Visibility="Hidden" Background="#ffeedd">

        </StackPanel>
        
        <!--ABSOLUTELY FAILED SCREEN: Player ran out of time before guessing any words (they found none of the words) -->
        <StackPanel x:Name="FailureResult" Visibility="Hidden" Background="#ffeedd">

        </StackPanel>
        <!--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~-->
        
        
        
        
    </Grid>
</Window>
