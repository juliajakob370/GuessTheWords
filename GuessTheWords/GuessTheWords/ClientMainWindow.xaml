<!--
    FILE          : ClientMainWindow.xaml
    PROJECT       : A02-TCPIP > Client-GuessTheWords
    PROGRAMMER    : Julia Jakob, Bibi Murwared Enayat Zada
    FIRST VERSION : 2026-02-09
    DESCRIPTION   : Main window XAML for the Guess The Word Game UI.
	                Has panels for the Start page and the actual game.
-->
<Window x:Class="Client_GuessTheWords.ClientMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GuessTheWords"
        mc:Ignorable="d"
        Title="Guess The Words Game!" Height="620" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <!--Start Page-->
        <!--BIBI!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!-->
        <StackPanel x:Name="StartPage" Visibility="Visible" Background="#ffeedd">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <TextBlock Grid.Row="0" Background="#FFDCB9" FontFamily="Kartika" FontSize="50" HorizontalAlignment="Center" FontWeight="ExtraBold" 
                           Padding="0,30,0,30" Foreground="#210f04" Text="Guess the Words 🔎"/>

                <!-- Main Content -->
                <Grid Grid.Row="1" Background="#ffeedd" Margin="0,30,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Welcome -->
                    <TextBlock Grid.Row="0" Text="Welcome!" FontFamily="Kartika" FontSize="30" FontWeight="ExtraBold" Foreground="#210f04" HorizontalAlignment="Center" Margin="0,20,0,10"/>

                    <!-- Name Label -->
                    <TextBlock Grid.Row="1" Text="Enter your name:" FontSize="18" FontWeight="Bold" Foreground="#210f04" HorizontalAlignment="Center" Margin="0,10,0,5"/>

                    <!-- Name TextBox -->
                    <TextBox x:Name="NameTextBox" Grid.Row="2" Width="320" Height="35" FontSize="16" Padding="8,4" HorizontalAlignment="Center" 
                             Background="White" BorderBrush="#210f04" BorderThickness="2" Margin="0,0,0,12"/>
                    
                    <!--Error message-->
                    <TextBlock x:Name="NameErrorText" Grid.Row="3" Foreground="Red" FontSize="12" HorizontalAlignment="Center"  Visibility="Collapsed"/>
                    
                    <!-- Usage or Rules -->
                    <Border Grid.Row="3" Background="#FFCB98" BorderBrush="#210f04" BorderThickness="3" CornerRadius="8" Padding="10" Margin="220,0,220,0">
                        <StackPanel>
                            <TextBlock Text="How to Play:" FontSize="14" FontWeight="Bold" Foreground="#210f04" TextAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="• Press START to begin the game." FontSize="13" Foreground="#210f04"/>
                            <TextBlock Text="• You will have 3 minutes to play." FontSize="13" Foreground="#210f04"/>
                            <TextBlock Text="• Find hidden words in the string." FontSize="13" Foreground="#210f04"/>
                            <TextBlock Text="• Words can appear forward or backward." FontSize="13" Foreground="#210f04"/>
                            <TextBlock Text="• Type a word and press GUESS to submit." FontSize="13" Foreground="#210f04"/>
                            <TextBlock Text="• You will get: Found / Not Found / Already Submitted." FontSize="13" Foreground="#210f04" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Start Button -->
                    <Button x:Name="StartButton" Grid.Row="5" Content="START!" Width="180" Height="45" FontSize="18" FontWeight="Bold" 
                            Background="#FF9832" Foreground="#210f04" BorderBrush="#210f04" BorderThickness="3" Margin="0,25,0,0" HorizontalAlignment="Center" Click="Start_Click" VerticalAlignment="Top"/>
                </Grid>
            </Grid>
        </StackPanel>
        <!--Game Page-->
        <!--Julia!!!!!!!!!!!!!!!!!!!!!!!!!!!!-->
        <StackPanel x:Name="GamePage" Visibility="Visible" Background="#ffeedd">
            <!--MAIN GRID-->
            <Grid>
                <Grid.RowDefinitions>
                    <!--0: Title and Help Button-->
                    <RowDefinition Height="Auto"/>
                    <!--1: String Space-->
                    <RowDefinition Height="Auto"/>
                    <!--2: Game Space-->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title and Help Button Grid-->
                <Grid Grid.Row="0" Background="#FFDCB9">
                    <Grid.ColumnDefinitions>
                        <!--0: Title and Help Button-->
                        <ColumnDefinition Width="0.8*"/>
                        <!--1: String Space-->
                        <ColumnDefinition Width="0.2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                            FontFamily="Kartika"
                            FontSize="50"
                            HorizontalAlignment="Center"
                            FontWeight="ExtraBold"
                            Padding="80,20"
                            Foreground="#210f04"
                            >
                        Guess the Words 🔎</TextBlock>

                    <Button Name="HelpButton"
                            Click="Help_Click"
                            Grid.Column="1"
                            FontFamily="Kartika"
                            Content="?"
                            FontSize="50"
                            Width="100"
                            Padding="5"
                            Height="70"
                            Foreground="#210f04"
                            Background="#FFDCB9"
                            BorderBrush="#210f04"
                            BorderThickness="5"
                            HorizontalAlignment="Center"/>
                </Grid>

                <!--String Space-->
                <TextBlock Name="StringSpace"
                           Grid.Row="1"
                           TextAlignment="Center"
                           Padding="20, 40"
                           FontSize="40"
                           Foreground="#210f04"
                    >ABCDCHANGETHISLATERPLEASEAAAAA</TextBlock>

                <!--Game Space Grid-->
                <Grid Grid.Row="2" Background="#FFCB98">
                    <Grid.ColumnDefinitions>
                        <!--0: User Input Side-->
                        <ColumnDefinition Width="*"/>
                        <!--1: Words Found Tracking Side-->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!--LEFT SIDE: User Input Side-->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <!--0: Guess Text Box Label-->
                            <RowDefinition Height="0.1*"/>
                            <!--1: Guess Text Input Box-->
                            <RowDefinition Height="0.1*"/>
                            <!--2: Guess Submit Button Space-->
                            <RowDefinition Height="0.1*"/>
                            <!--3: Space for Feedback on Guess-->
                            <RowDefinition Height="0.3*"/>
                            <!--4: Timer Label-->
                            <RowDefinition Height="0.1*"/>
                            <!--5: Timer Display-->
                            <RowDefinition Height="0.2*"/>
                            <!--6: Time Unit Labels-->
                            <RowDefinition Height="0.1*"/>
                        </Grid.RowDefinitions>

                        <!--Guess Text Box Label-->
                        <TextBlock Name="GuessTextBoxLabel"
                                   Grid.Row="0"
                                   FontWeight="Bold"
                                   FontSize="20"
                                   Padding="10"
                                   HorizontalAlignment="Center"
                                   Foreground="#210f04"
                                   >ENTER GUESS:</TextBlock>

                        <!--Guess Text Input Box-->
                        <TextBox Name="GuessTextBox"
                                 Grid.Row="1"
                                 Padding="5"
                                 HorizontalAlignment="Center"
                                 Width="350"
                                 FontSize="15"
                                 ></TextBox>

                        <!--Guess Submit Button-->
                        <Button Name="SubmitGuessButton"
                                Click="SubmitGuess_Click"
                                Grid.Row="2"
                                Content="GUESS!"
                                Width="200"
                                Padding="2"
                                Margin="0,10"
                                Background="#FF9832"
                                Foreground="#210f04"
                                BorderBrush="#210f04"
                                FontWeight="Bold"
                                FontSize="15"
                                />

                        <!--Guess Feedback Space -->
                        <TextBlock Name="GuessFeedback"
                                   Grid.Row="3"
                                   Padding="5"
                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   ></TextBlock>

                        <!--Timer Label-->
                        <TextBlock Name="TimerLabel"
                                   Grid.Row="4"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   Padding="0,50,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="#210f04"
                       
                                   >
                            TIME LEFT
                        </TextBlock>

                        <!--Timer-->
                        <TextBlock Name="TimerDisplay"
                                   Grid.Row="5"
                                   FontSize="70"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="#43B3AE"
                                   HorizontalAlignment="Center"
                                   >00:00</TextBlock>

                        <!--Time Unit Labels-->
                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <!--0: Minutes-->
                                <ColumnDefinition Width="*"/>
                                <!--1: Seconds-->
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!--Minutes Label-->
                            <TextBlock Name="MinutesLabel"
                                       Grid.Column="0"
                                       HorizontalAlignment="Right"
                                       FontWeight="ExtraBold"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       Padding="0,0,40,10"
                                       Foreground="#266663"
                                >
                                MIN
                            </TextBlock>

                            <!--Seconds Label-->
                            <TextBlock Name="SecondsLabel"
                                       Grid.Column="1"
                                       HorizontalAlignment="Left"
                                       FontWeight="ExtraBold"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       Padding="40,0,0,10"
                                       Foreground="#266663"
                                >
                                SEC
                            </TextBlock>
                        </Grid>
                    </Grid>

                    <!--RIGHT SIDE: Words Found Side-->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <!--0: Info-->
                            <RowDefinition Height="1*"/>
                            <!--1: List Box of Found Words-->
                            <RowDefinition Height="3*"/>
                        </Grid.RowDefinitions>

                        <!--Info-->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <!--0: Label-->
                                <ColumnDefinition Width="2*"/>
                                <!--1: Word Score-->
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Name="WordsFoundLabel"
                                       Grid.Column="0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="30"
                                       FontWeight="Bold"
                                >
                                WORDS FOUND:
                            </TextBlock>
                            <TextBlock Name="WordsFoundCount"
                                       Grid.Column="1"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="#1C4D4A"
                                >
                                30/30
                            </TextBlock>
                        </Grid>

                        <!--List Box of Found Words-->
                        <ListBox Name="FoundWordsList" 
                                 Grid.Row="1"
                                 Height="250"
                                 Width="350"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Background="#E3F5F4"
                                 Foreground="#4E794E"
                                 FontWeight="Bold"
                                 FontFamily="Arial Rounded MT Bold"
                                 FontSize="15"
                                 Padding="5"
                            />
                    </Grid>


                </Grid>

            </Grid>
        </StackPanel>

        <!--ALL THE RESULTS PANELS~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~-->
        <!--WIN SCREEN: Player found all the words before the time ran out-->
        <StackPanel x:Name="WinResult" Visibility="Hidden" Background="#BFE1BF">
            <Grid>
                <Grid.RowDefinitions>
                    <!--0: Result-->
                    <RowDefinition Height="Auto"/>
                    <!--1: Intro to Score-->
                    <RowDefinition Height="Auto"/>
                    <!--2: Game Score-->
                    <RowDefinition Height="Auto"/>
                    <!--3: Words-->
                    <RowDefinition Height="Auto"/>
                    <!--4: Message for user-->
                    <RowDefinition Height="Auto"/>
                    <!--5: Buttons-->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!--Result Title-->
                <TextBlock Name="WinResultTitle"
                           Grid.Row="0"
                           Foreground="#1D3D1D"
                           FontSize="80"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontFamily="Kartika"
                           Padding="20"
                           >
                    🏆 WINNER!! 🏆
                </TextBlock>

                <!--Intro to Score-->
                <TextBlock Name="WinIntroToScore"
                           Grid.Row="1"
                           Foreground="#1D3D1D"
                           FontSize="40"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontFamily="Courier New"
                           >
                    YOU FOUND:
                </TextBlock>

                <!--Game Score-->
                <TextBlock Name="WinWordScore"
                           Grid.Row="2"
                           Foreground="#266663"
                           FontSize="100"
                           FontWeight="ExtraBold"
                           HorizontalAlignment="Center"
                           FontFamily="Arial Rounded MT Bold"
                           Padding="20"
                           >
                    30/30
                </TextBlock>

                <!--Words-->
                <TextBlock Name="WinWords"
                           Grid.Row="3"
                           Foreground="#1D3D1D"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontFamily="Courier New"
                           >
                    WORDS BEFORE THE TIME RAN OUT!
                </TextBlock>
                <!--Message (update with player name upon winning)-->
                <TextBlock Name="WinMessage"
                           Grid.Row="4"
                           Foreground="#1D3D1D"
                           FontSize="30"
                           Padding="25"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontFamily="Courier New"
                           >
                    Great job, Name!
                </TextBlock>

                <!--Buttons-->
                <Grid Name="WinButtonsGrid"
                      Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <!--0: Quit-->
                        <ColumnDefinition Width="*"/>
                        <!--1: Play Again-->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Name="WinQuitButton"
                            Click="Quit_Click"
                            Grid.Column="0"
                            Content="QUIT"
                            Width="200"
                            Background="#BFE1BF"
                            Foreground="#1D3D1D"
                            BorderBrush="#1D3D1D"
                            BorderThickness="3"
                            Margin="25"
                            Padding="10"
                            FontWeight="Bold"
                            FontSize="25"
                            HorizontalAlignment="Center"
                            />

                    <Button Name="WinPlayAgainButton"
                            Click="PlayAgain_Click"
                            Grid.Column="1"
                            Content="PLAY AGAIN"
                            Width="200"
                            Background="#42B39A"
                            Foreground="#1D3D1D"
                            BorderBrush="#1D3D1D"
                            BorderThickness="3"
                            Margin="25"
                            Padding="10"
                            FontWeight="Bold"
                            FontSize="25"
                            HorizontalAlignment="Center"
                            />
                </Grid>

            </Grid>
        </StackPanel>

        <!--OUT OF TIME SCREEN: Player ran out of time before finding all the words-->
        <StackPanel x:Name="TimeOutResult" Visibility="Hidden" Background="#C9E8EE">
            <Grid>
                <Grid.RowDefinitions>
                    <!--0: Result-->
                    <RowDefinition Height="Auto"/>
                    <!--1: Intro to Score-->
                    <RowDefinition Height="Auto"/>
                    <!--2: Game Score-->
                    <RowDefinition Height="Auto"/>
                    <!--3: Words-->
                    <RowDefinition Height="Auto"/>
                    <!--4: Message for user-->
                    <RowDefinition Height="Auto"/>
                    <!--5: Buttons-->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!--Result Title-->
                <TextBlock Name="TimeOutResultTitle"
                           Grid.Row="0"
                           Foreground="#0F2A30"
                           FontSize="80"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontFamily="Kartika"
                           Padding="20"
                           >
                    ⌛ OUT OF TIME! ⌛
                </TextBlock>

                <!--Intro to Score-->
                <TextBlock Name="TimeOutIntroToScore"
                           Grid.Row="1"
                           Foreground="#0F2A30"
                           FontSize="40"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontFamily="Courier New"
                           >
                    YOU FOUND:
                </TextBlock>

                <!--Game Score-->
                <TextBlock Name="TimeOutWordScore"
                           Grid.Row="2"
                           Foreground="#266663"
                           FontSize="100"
                           FontWeight="ExtraBold"
                           HorizontalAlignment="Center"
                           FontFamily="Arial Rounded MT Bold"
                           Padding="20"
                           >
                    10/30
                </TextBlock>

                <!--Words-->
                <TextBlock Name="TimeOutWords"
                           Grid.Row="3"
                           Foreground="#0F2A30"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontFamily="Courier New"
                           >
                    WORDS BEFORE THE TIME RAN OUT!
                </TextBlock>
                <!--Message (update with player name upon Time Out)-->
                <TextBlock Name="TimeOutMessage"
                           Grid.Row="4"
                           Foreground="#0F2A30"
                           FontSize="30"
                           Padding="25"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontFamily="Courier New"
                           >
                    Good job, Name! Can you do better?
                </TextBlock>

                <!--Buttons-->
                <Grid Name="TimeOutButtonsGrid"
                      Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <!--0: Quit-->
                        <ColumnDefinition Width="*"/>
                        <!--1: Play Again-->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Name="TimeOutQuitButton"
                            Click="Quit_Click"
                            Grid.Column="0"
                            Content="QUIT"
                            Width="200"
                            Background="Transparent"
                            Foreground="#0F2A30"
                            BorderBrush="#0F2A30"
                            BorderThickness="3"
                            Margin="25"
                            Padding="10"
                            FontWeight="Bold"
                            FontSize="25"
                            HorizontalAlignment="Center"
                            />

                    <Button Name="TimeOutPlayAgainButton"
                            Click="PlayAgain_Click"
                            Grid.Column="1"
                            Content="PLAY AGAIN"
                            Width="200"
                            Background="#3594A7"
                            Foreground="#0F2A30"
                            BorderBrush="#0F2A30"
                            BorderThickness="3"
                            Margin="25"
                            Padding="10"
                            FontWeight="Bold"
                            FontSize="25"
                            HorizontalAlignment="Center"
                            />
                </Grid>
            </Grid>
        </StackPanel>

        <!--ABSOLUTELY FAILED SCREEN: Player ran out of time before guessing any words (they found none of the words) -->
        <StackPanel x:Name="FailureResult" Visibility="Hidden" Background="#E2ACAC">
            <Grid>
                <Grid.RowDefinitions>
                    <!--0: Result-->
                    <RowDefinition Height="Auto"/>
                    <!--1: Intro to Score-->
                    <RowDefinition Height="Auto"/>
                    <!--2: Game Score-->
                    <RowDefinition Height="Auto"/>
                    <!--3: Words-->
                    <RowDefinition Height="Auto"/>
                    <!--4: Message for user-->
                    <RowDefinition Height="Auto"/>
                    <!--5: Buttons-->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!--Result Title-->
                <TextBlock Name="LoserResultTitle"
                           Grid.Row="0"
                           Foreground="#3F1616"
                           FontSize="80"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontFamily="Kartika"
                           Padding="20"
                           >
                    ⌛ OUT OF TIME! ⌛
                </TextBlock>

                <!--Intro to Score-->
                <TextBlock Name="LoserIntroToScore"
                           Grid.Row="1"
                           Foreground="#3F1616"
                           FontSize="40"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontFamily="Courier New"
                           >
                    YOU FOUND:
                </TextBlock>

                <!--Game Score-->
                <TextBlock Name="LoserWordScore"
                           Grid.Row="2"
                           Foreground="#933434"
                           FontSize="100"
                           FontWeight="ExtraBold"
                           HorizontalAlignment="Center"
                           FontFamily="Arial Rounded MT Bold"
                           Padding="20"
                           >
                    0/30
                </TextBlock>

                <!--Words-->
                <TextBlock Name="LoserWords"
                           Grid.Row="3"
                           Foreground="#3F1616"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontFamily="Courier New"
                           >
                    WORDS BEFORE THE TIME RAN OUT!
                </TextBlock>
                <!--Message (update with player name upon Time Out)-->
                <TextBlock Name="LoserMessage"
                           Grid.Row="4"
                           Foreground="#3F1616"
                           FontSize="30"
                           Padding="25"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontFamily="Courier New"
                           >
                    Name, you found no words 😢
                </TextBlock>

                <!--Buttons-->
                <Grid Name="LoserButtonsGrid"
                      Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <!--0: Quit-->
                        <ColumnDefinition Width="*"/>
                        <!--1: Play Again-->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Name="LoserQuitButton"
                            Click="Quit_Click"
                            Grid.Column="0"
                            Content="QUIT"
                            Width="200"
                            Background="Transparent"
                            Foreground="#3F1616"
                            BorderBrush="#3F1616"
                            BorderThickness="3"
                            Margin="25"
                            Padding="10"
                            FontWeight="Bold"
                            FontSize="25"
                            HorizontalAlignment="Center"
                            />

                    <Button Name="LoserPlayAgainButton"
                            Click="PlayAgain_Click"
                            Grid.Column="1"
                            Content="PLAY AGAIN"
                            Width="200"
                            Background="#A83B3B"
                            Foreground="#3F1616"
                            BorderBrush="#3F1616"
                            BorderThickness="3"
                            Margin="25"
                            Padding="10"
                            FontWeight="Bold"
                            FontSize="25"
                            HorizontalAlignment="Center"
                            />
                </Grid>
            </Grid>
        </StackPanel>
        <!--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~-->
    </Grid>
</Window>
