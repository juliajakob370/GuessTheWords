<?xml version="1.0" encoding="utf-8" ?>
<!--
 * FILE             : ClientApp.config
 * PROJECT          : GuessTheWords-A02 > Client
 * PROGRAMMER       : Bibi Murwared
 * FIRST VERSION    : 2026-02-16
 * DESCRIPTION      : This file contains default values and valid ranges for the client settings.
-->
<configuration>
	<appSettings>
		<!-- Network settings for the game server -->
		<add key="ServerIP" value="127.0.0.1" />
		<add key="ServerPort" value="12345" />

		<!-- Protocol settings -->
		<add key="ProtocolVersion" value="GTW/1.0" />
		
		<!-- This is the END  hahahaha  hold your breath and count to 10  -->
		<add key="EndLine" value="END" />

		<!-- client buffer size for reading from the server -->
		<add key="ReadBufferSize" value="1024" />

		<!-- Player name limits -->
		<add key="MaxNameLength" value="20" />

		<!-- Client log file base name -->
		<add key="LogFileName" value="client.log" />

		<!-- Validation ranges  -->
		<add key="MinPort" value="1024" />
		<add key="MaxPort" value="65535" />
		<add key="MinBufferSize" value="64" />
		<add key="MaxBufferSize" value="65536" />
		<add key="MinNameLength" value="1" />
		<add key="MaxNameLengthLimit" value="50" />
	</appSettings>
</configuration>

